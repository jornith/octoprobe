# Personal access token (classic or fine-grained). Optional: without it the suite
# runs against the anonymous 60 req/hour tier and skips authenticated-only tests.
GITHUB_TOKEN=ghp_replace_me

# Override only when pointing the framework at a proxy or a mock.
# GITHUB_API_BASE_URL=https://api.github.com

# Per-request timeout in seconds.
# REQUEST_TIMEOUT=10
